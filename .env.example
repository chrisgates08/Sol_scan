# ── Telegram ──────────────────────────────────────────────────
# Obtenez votre token via @BotFather sur Telegram
TELEGRAM_BOT_TOKEN=your_bot_token_here

# Obtenez votre Chat ID via @userinfobot sur Telegram
TELEGRAM_CHAT_ID=your_chat_id_here

# ── GoPlus Security API ───────────────────────────────────────
# OPTIONNEL — Sans ces variables, le mode gratuit s'applique
# automatiquement (30 req/min, aucune auth requise).
#
# Pour le mode authentifié (quota plus élevé) :
# 1. Créez un compte sur https://platform.gopluslabs.io
# 2. Créez une application → récupérez app_key et app_secret
# 3. Renseignez les deux variables ci-dessous
GOPLUS_APP_KEY=
GOPLUS_APP_SECRET=
